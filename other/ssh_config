Host brick slab paper tmux
    User user
    Port 8022
    IdentityFile ${HOME}/.ssh/ssh_ed25519
    IdentitiesOnly yes
    CheckHostIP no
    StrictHostKeyChecking no

    HashKnownHosts no
    ForwardX11 no
    AddressFamily inet

Host brick
    Hostname android.local

Host slab
    Hostname 192.168.0.0

Host paper
    Hostname 192.168.0.0

Host github.com gitlab.com codeberg.org
    User git
    IdentityFile ${HOME}/.ssh/git_ed25519
