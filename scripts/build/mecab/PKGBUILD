pkgname=mecab-git
pkgrel=1
pkgver=r157.61b90ba
pkgdesc="Yet another part-of-speech and morphological analyzer."
arch=($CARCH)
url="https://taku910.github.io/mecab"
depends=()
makedepends=('git')
conflicts=('mecab')
provides=('mecab')
license=('BSD-3-Clause AND GPL-2.0-or-later AND LGPL-2.1-or-later')
source=(
    "${pkgname}::git+https://github.com/taku910/mecab.git"
    'src-dictionary.cpp.patch'
    # 'config.guess'
    # 'config.sub'
)
sha512sums=(
    'SKIP'
    'f708700899ad07233d4df6cc61a529cbc50bbfb7eb7c20736bf6e13fdb27f730b1906150b56d9af5decdcc60756e7a6a7c8aa612559da4b8dccc7468b78be804'
    # 'fb913a726dc231cc641e966a1aadf5899c1deb972ac17d7ea03b3574043d136354d981e7214900b37e850048d8015731be88b9f7ef09f1b0f3d585e24b2bcd3e'
    # '29627df4706b7b72c1e70fdb589377740dd00184d4b1beb851121ad0c5241a585d0a7c8220b27e7dfe9238cda3c3e99db72f1c1349feb72b98480180647ef52b'
)
options=(!strip) # TODO: rm

pkgver() {
    cd "${srcdir}/${pkgname}"
    (
        set -o pipefail
        git describe --long --tag --abbrev=7 2>/dev/null | sed 's/^v//g;s/\([^-]*-g\)/r\1/;s/-/./g' ||
            printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
    )
}

prepare() {
    git -C "${srcdir}/${pkgname}" clean -dfx
}

build() {
    cd "${pkgname}/mecab"

    echo "==> Updating config.guess and config.sub..."
    curl -Lo config.guess 'http://git.savannah.gnu.org/gitweb/?p=config.git;a=blob_plain;f=config.guess;hb=HEAD'
    curl -Lo config.sub 'http://git.savannah.gnu.org/gitweb/?p=config.git;a=blob_plain;f=config.sub;hb=HEAD'
    # cp "${srcdir}/config.guess" config.guess
    # cp "${srcdir}/config.sub" config.sub


    echo "==> Configuring..."
    ./configure --build aarch64-unknown-linux --with-charset=utf-8 \
        --prefix $PREFIX --sysconfdir $PREFIX/etc --libexecdir $PREFIX/lib \
        CPPFLAGS="-O3 -Wall -Wno-register -mno-outline-atomics "

    echo "==> Patching..."
    patch src/dictionary.cpp < "${srcdir}/src-dictionary.cpp.patch"

    echo "==> Making..."
    make
}

check() {
    cd "${pkgname}/mecab"
    make -k check
}

package() {
    cd "${pkgname}/mecab"
    make DESTDIR="$pkgdir/" install
}
