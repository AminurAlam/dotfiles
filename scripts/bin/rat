#!/usr/bin/env fish

cd "/sdcard/Tachi/downloads/HentaiNexus (EN)/"
set chapter (path basename "$argv[1]")
[ -e "$chapter" ] || exit 1

set artist (
    unzip -p $chapter/Chapter.cbz ComicInfo.xml \
    | rg --only-matching --replace '$2' '<(Penciller|Writer)>(.*)</(Penciller|Writer)>'
)

[ -z "$artist" ] && exit 2

mv -iv "$chapter" "@$artist - $chapter"
