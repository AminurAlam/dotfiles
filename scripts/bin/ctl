#!/usr/bin/fish --no-config

switch $argv[1]
    case vol # (+|-)?     toggle or change vol
        if [ -n "$argv[2]" ]
            wpctl set-volume @DEFAULT_AUDIO_SINK@ (math 2 x (printf $argv[2] | wc -c))%$(string sub -l1 -- $argv[2])
            notify-send -h string:x-canonical-private-synchronous:volume -t 500 "Volume: $(wpctl get-volume @DEFAULT_AUDIO_SINK@ | tr -dc [:digit:] | math)"
        else
            wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
            wpctl get-volume @DEFAULT_AUDIO_SINK@ | rg -q MUTED
            and notify-send -h string:x-canonical-private-synchronous:mute -t 500 "󰸈 MUTED"
            or notify-send -h string:x-canonical-private-synchronous:mute -t 500 "󰖀 AUDIBLE"
        end

    case mic #            toggle mic on/off
        wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
        wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | rg -q MUTED
        and notify-send -h string:x-canonical-private-synchronous:mic -t 500 " MUTED"
        or notify-send -h string:x-canonical-private-synchronous:mic -t 500 " AUDIBLE"

    case lum # <+|-> [n]  change brightness
        set a 1
        [ -z "$argv[3]" ]
        and set argv[3] 2
        if false # command -v brightnessctl
            notify-send -h string:x-canonical-private-synchronous:brightness -t 500 \
                "Brightness: $(
                brightnessctl set $argv[3]%$argv[2] \
                | rg --replace '$1' '^\tCurrent brightness: \d+ \((\d+%)\)$'
            )"
        else
            set device /sys/class/backlight/amdgpu_bl1
            set max (cat $device/max_brightness)
            set cur (cat $device/brightness)

            [ -z "$argv[3]" ]
            and set argv[3] 1

            [ -w "$device/brightness" ]
            or foot -- sudo chown -R $USER "$device/brightness"

            set new (math -s0 -m ceiling "$cur $argv[2] ($max x $argv[3] / 100)")
            [ $new -lt 0 ] && set new 0
            [ $new -gt $max ] && set new $max

            echo $new >$device/brightness

            notify-send -h string:x-canonical-private-synchronous:brightness -t 500 \
                "Brightness: $(math -s0 "100 x ($new / $max)")%"
        end

    case pow # (up|down)  change powerprofile
        # TODO: rollback instead
        # TODO: next|prev
        set current (powerprofilesctl get)
        if [ "$argv[2]" = up -a "$current" = balanced ]
            notify-send -h string:x-canonical-private-synchronous:power -t 500 " PERFORMANCE"
            powerprofilesctl set performance
        else if [ "$argv[2]" = up -a "$current" = power-saver ] \
                || [ "$argv[2]" = down -a "$current" = performance ]
            notify-send -h string:x-canonical-private-synchronous:power -t 500 " BALANCED"
            powerprofilesctl set balanced
        else if [ "$argv[2]" = down -a "$current" = balanced ]
            notify-send -h string:x-canonical-private-synchronous:power -t 500 " POWER-SAVER"
            powerprofilesctl set power-saver
        end

    case lim #            toggle battery limit
        set file /sys/bus/platform/drivers/ideapad_acpi/VPC2004:00/conservation_mode
        set bit $(math bitxor 1,(cat $file))

        [ -w "$file" ]
        and echo $bit | tee $file
        or echo $bit | sudo tee $file # TODO: sudo -> something that works in gui

        [ "$(cat $file)" = 1 ]
        and notify-send -h string:x-canonical-private-synchronous:limit -t 500 " BATTERY LIMITED"
        or notify-send -h string:x-canonical-private-synchronous:limit -t 500 " BATTERY UNLOCKED"

    case ss # (full|ocr)? take screenshot
        set filename Screenshot_(date +'%Y%m%d_%H%M%S')_grim.png

        if [ "$argv[2]" = full ]
            grim $XDG_PICTURES_DIR/ss/$filename && notify-send "$filename taken"
        else if [ "$argv[2]" = ocr ]
            grim -g (slurp) - | wl-copy -t image/png
        else
            grim -g (slurp) $XDG_PICTURES_DIR/ss/$filename && notify-send "$filename taken"
        end

    case ssend #          send screenshot to phone
        fd . $XDG_PICTURES_DIR/ss/ -a --changed-within 10min -X rsync -Pha '{}' brick:/sdcard/Download/
        fd . $XDG_PICTURES_DIR/ss/ -a --changed-within 10min -x notify-send -t 2000 -i '{}' 'sent {/}'

    case rec #            screen record
        # niri msg -j casts
        set wfid (pidof wf-recorder)
        if [ -n "$wfid" ]
            set file (cat /proc/$wfid/cmdline | string split0)[-1]
            kill -s INT "$wfid"
            wait wf-recorder

            set thumbnail (mktemp -t ctl-XXXXXX).png

            ffmpeg -y -hide_banner -stats -loglevel error -i $file -an -sn -dn -vframes 1 $thumbnail

            notify-send -t 1500 -i $thumbnail "󰨜 RECORDING SAVED in $file"
        else
            # TODO: fix audio
            wf-recorder -r 30 -p "br=5M" -f (date +'%Y-%m-%d_%H%M_%S').mp4
        end

    case picker #         color picker
        set hex (niri msg pick-color | string match -gr '(#[[:xdigit:]]+)')
        set size 100
        set svg '<svg viewBox="0 0 '$size' '$size'" width="'$size'pt" height="'$size'pt"> <path fill="'$hex'" fill-rule="nonzero" d="M 0 0v '$size' h '$size' v -'$size' Z " /> </svg>'
        notify-send -t 1500 -i (echo $svg | psub) $hex
        wl-copy -n $hex

    case sys #            show status of user units
        systemctl --user status --full --no-pager -n0 (path basename  ~/.config/systemd/user/*.service)

    case toggle-width #   toggle between 50% width and maximize-window-to-edges
        set json (niri msg -j focused-window)
        if [ (printf "%s" "$json" | jq .is_floating) = false ]
            # use this if you have goofy sizes
            # niri msg -j focused-output | jq .logical

            # if max-width
            [ (printf "%s" "$json" | jq '.layout.window_size[0]') = 1920 ]
            and niri msg action set-column-width 50%
            or niri msg action maximize-window-to-edges

            # if fullscreen
            test (niri msg -j focused-window | jq '.layout.window_size[1]') = 1080
            and niri msg action fullscreen-window

            true
        else
            niri msg action set-window-width (
                math -s0 (
                    printf "%s" "$json" | jq .layout.window_size[1]
                ) x 16 / 9
            )
        end
    case browser #        focus to existing browser instance or spawn it
        set id (niri msg -j windows | jq '.[] | select(.app_id == "librewolf") | .id')
        [ -n "$id" ]
        and niri msg action focus-window --id $id
        or librewolf

    case launcher #       lauch or close launcher
        pidof fuzzel
        and pkill fuzzel
        or fuzzel

    case wp # <filepath>  set wallpaper
        # TODO: auto tile small images
        # TODO: pick if no filename given
        if [ -e "$argv[2]" ]
            killall swaybg
            if [ (math (mediainfo --Output=JSON --Output="Image;%Width% + %Height%" $argv[2])) -le 3000 ]
                swaybg -m tile -i $argv[2] & disown
            else
                swaybg -m fill -i $argv[2] & disown
            end
        end

    case opacity # 0-255  set terminal opacity
        printf "\033]11;rgba:24/28/3b/$(math --base 16 $argv[2] | string replace 0x '')\007"

    case '*' #            print help
        printf 'USAGE:\n'
        rg --replace '$1' '^    case ([^\s]+) #' (status filename)
end
